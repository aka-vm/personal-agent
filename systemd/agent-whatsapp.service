[Unit]
Description=Personal Agent — WhatsApp adapter
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/vineet/agent
ExecStart=/usr/bin/python3 -u /home/vineet/agent/adapters/whatsapp_bot.py
Restart=always
RestartSec=10
StandardOutput=append:/home/vineet/agent/logs/whatsapp.log
StandardError=append:/home/vineet/agent/logs/whatsapp.log

[Install]
WantedBy=default.target
