[Unit]
Description=Personal Agent — Telegram adapter
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/vineet/agent
ExecStart=/usr/bin/python3 -u /home/vineet/agent/adapters/telegram_bot.py
Restart=always
RestartSec=10
# See agent-whatsapp.service: SIGTERM only the main bot so restart doesn't hang on
# the in-flight `claude` subprocess.
KillMode=mixed
TimeoutStopSec=15
StandardOutput=append:/home/vineet/agent/logs/telegram.log
StandardError=append:/home/vineet/agent/logs/telegram.log

[Install]
WantedBy=default.target
