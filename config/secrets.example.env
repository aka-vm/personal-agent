# Agent secrets — copy to ~/.config/agent/secrets.env, fill in, chmod 600.
# NEVER commit the real file. Only this .example is tracked.

# Telegram bot token from @BotFather.
TELEGRAM_BOT_TOKEN=123456:ABC-your-token-here

# Brave Search API key (free 2k/mo) from api-dashboard.search.brave.com — optional.
BRAVE_API_KEY=
